<!DOCTYPE html>
<html>
<head>
    <title>Recently Deleted Pets</title>
</head>
<body>

<h1>Recently Deleted Pets</h1>

<a href="/pets">Back to Pets</a>

<% if (pets.length === 0) { %>
    <p>No deleted pets.</p>
<% } else { %>

    <% pets.forEach(pet => { %>

        <div class="card">
            <img src="/images/<%= pet.image %>" width="200">

            <h3><%= pet.pet_name %></h3>

            <p>Breed: <%= pet.breed %></p>

            <p>Age: <%= pet.age %></p>

            <a href="/restorePet/<%= pet.petId %>"
               class="btn btn-success">
                Restore
            </a>

            <a href="/permanentDelete/<%= pet.petId %>"
               class="btn btn-danger"
               onclick="return confirm('Are you sure you want to permanently delete this pet?')">
                Delete Forever
            </a>

        </div>

        <hr>

    <% }) %>

<% } %>

</body>
</html>
