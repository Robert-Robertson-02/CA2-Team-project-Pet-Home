<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Filtered Pets</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <h1 class="text-center mb-4 fw-bold">Filtered Results</h1>
    
    <a href="/filter" class="btn btn-secondary mb-4">Back to Filter</a>

    <% if (pet.length === 0) { %>
      <p class="text-center text-muted">No pets match your filters.</p>
    <% } else { %>
      <div class="row">
        <% pet.forEach(p => { %>
          <%- include('partials/card', { pet: p }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>

