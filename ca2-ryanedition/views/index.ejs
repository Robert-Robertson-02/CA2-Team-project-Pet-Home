<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Pet Home - Find Your Perfect Companion</title>
</head>
<body>
      <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/">Pet Home</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav">
              <% if (user) { %>
                <li class="nav-item">
                  <a class="nav-link" href="/add">Add Pet</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/logout">Logout</a>
                </li>
              <% } else { %>
                <li class="nav-item">
                  <a class="nav-link" href="/register">Register</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/login">Login</a>
                </li>
              <% } %>
            </ul>
          </div>
        </div>
      </nav>

    <div class="container mt-4">
        <h1 class="text-center mb-4">Available Pets for Adoption</h1>
        
        <!-- Search and Filter Section -->
        <div class="row mb-4">
            <div class="col-md-12">
                <form action="/" method="GET" class="row g-3">
                    <div class="col-md-4">
                        <input type="text" class="form-control" name="search" placeholder="Search by name, breed, or type..." value="<%= searchQuery || '' %>">
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" name="animal_type">
                            <option value="">All Types</option>
                            <option value="Dog" <%= animalTypeFilter === 'Dog' ? 'selected' : '' %>>Dog</option>
                            <option value="Cat" <%= animalTypeFilter === 'Cat' ? 'selected' : '' %>>Cat</option>
                            <option value="Bird" <%= animalTypeFilter === 'Bird' ? 'selected' : '' %>>Bird</option>
                            <option value="Rabbit" <%= animalTypeFilter === 'Rabbit' ? 'selected' : '' %>>Rabbit</option>
                            <option value="Hamster" <%= animalTypeFilter === 'Hamster' ? 'selected' : '' %>>Hamster</option>
                            <option value="Fish" <%= animalTypeFilter === 'Fish' ? 'selected' : '' %>>Fish</option>
                            <option value="Reptile" <%= animalTypeFilter === 'Reptile' ? 'selected' : '' %>>Reptile</option>
                            <option value="Other" <%= animalTypeFilter === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" name="sort">
                            <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                            <option value="oldest" <%= sortBy === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                            <option value="name_asc" <%= sortBy === 'name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
                            <option value="name_desc" <%= sortBy === 'name_desc' ? 'selected' : '' %>>Name (Z-A)</option>
                            <option value="age_asc" <%= sortBy === 'age_asc' ? 'selected' : '' %>>Age (Youngest)</option>
                            <option value="age_desc" <%= sortBy === 'age_desc' ? 'selected' : '' %>>Age (Oldest)</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Apply Filters</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Messages Section -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <!-- Results Summary -->
        <div class="row mb-3">
            <div class="col-md-12">
                <p class="text-muted">
                    Showing <strong><%= pets.length %></strong> pet<% if (pets.length !== 1) { %>s<% } %> 
                    <% if (searchQuery || animalTypeFilter) { %>
                        matching your criteria
                    <% } %>
                </p>
            </div>
        </div>

        <!-- Pet Cards Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% if (pets && pets.length > 0) { %>
                <% pets.forEach(function(pet) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <!-- Pet Image -->
                            <div class="card-img-top" style="height: 200px; overflow: hidden; background-color: #f8f9fa;">
                                <% if (pet.image_path) { %>
                                    <img src="<%= pet.image_path %>" alt="<%= pet.pet_name %>" style="width: 100%; height: 100%; object-fit: cover;">
                                <% } else { %>
                                    <div class="d-flex justify-content-center align-items-center h-100 text-secondary">
                                        <span style="font-size: 4rem;">🐾</span>
                                    </div>
                                <% } %>
                            </div>
                            
                            <!-- Pet Details -->
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= pet.pet_name %>
                                    <span class="badge bg-secondary float-end">
                                        <%= pet.animal_type || 'Unknown' %>
                                    </span>
                                </h5>
                                
                                <div class="mb-2">
                                    <span class="badge bg-info me-1">Age: <%= pet.age || 'Unknown' %></span>
                                    <span class="badge bg-warning text-dark">Breed: <%= pet.breed || 'Unknown' %></span>
                                </div>

                                <% if (pet.description) { %>
                                    <p class="card-text text-muted" style="font-size: 0.9rem;">
                                        <%= pet.description.length > 100 ? pet.description.substring(0, 100) + '...' : pet.description %>
                                    </p>
                                <% } %>

                                <p class="card-text" style="font-size: 0.8rem;">
                                    <small class="text-muted">
                                        Added by: <%= pet.username || 'Unknown User' %>
                                    </small>
                                </p>

                                <!-- View Details Button -->
                                <a href="/pet/<%= pet.pet_id %>" class="btn btn-outline-primary btn-sm w-100">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12">
                    <div class="alert alert-info text-center p-5">
                        <h4>No Pets Found</h4>
                        <p>We don't have any pets matching your criteria at the moment.</p>
                        <a href="/" class="btn btn-primary mt-2">Clear Filters</a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <footer class="bg-light text-center text-muted py-3 mt-5">
        <div class="container">
            <p class="mb-0">Pet Home - Find Your Perfect Companion © 2026</p>
        </div>
    </footer>
</body>
</html>