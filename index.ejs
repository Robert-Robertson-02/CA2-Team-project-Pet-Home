<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Pet Home - Find Your Perfect Companion</title>
</head>
<body>
    <!-- Navigation Bar-->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Pet Home</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Browse Pets</a>
                    </li>
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/add">Add Pet</a>
                        </li>
                    <% } %>
                </ul>
                <ul class="navbar-nav">
                    <% if (user) { %>
                        <li class="nav-item">
                            <span class="navbar-text me-3">
                                Welcome, <%= user.username %>
                                <% if (user.role === 'admin') { %>
                                    <span class="badge bg-warning text-dark">Admin</span>
                                <% } else { %>
                                    <span class="badge bg-info">User</span>
                                <% } %>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/logout">Logout</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/register">Register</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p><%= error %></p>
                <% }); %>
            </div>
        <% } %>
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="bg-primary text-white text-center p-5 rounded mb-4">
            <h1>Find Your Perfect Companion</h1>
            <p>Browse our adorable pets waiting for their forever home</p>
            <div class="mt-3">
                <span class="badge bg-light text-dark p-2">
                    <%= pets.length %> pets available
                </span>
            </div>
        </div>

        <!-- Search and Filter -->
        <div class="bg-light p-4 rounded mb-4">
            <form action="/" method="GET" class="row g-3">
                <div class="col-md-5">
                    <label for="search" class="form-label">Search Pets</label>
                    <input type="text" id="search" name="search" class="form-control" 
                           placeholder="Search by name, breed, or type..." 
                           value="<%= searchTerm || '' %>">
                </div>
                <div class="col-md-3">
                    <label for="filterType" class="form-label">Filter by Type</label>
                    <select id="filterType" name="type" class="form-select">
                        <option value="">All Types</option>
                        <%  
                            const types = [];
                            for (let i = 0; i < pets.length; i++) {
                                if (pets[i].animal_type && !types.includes(pets[i].animal_type)) {
                                    types.push(pets[i].animal_type);
                                }
                            }
                            for (let i = 0; i < types.length; i++) { 
                        %>
                            <option value="<%= types[i] %>" <%= selectedType === types[i] ? 'selected' : '' %>>
                                <%= types[i] %>
                            </option>
                        <% } %>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="sortBy" class="form-label">Sort By</label>
                    <select id="sortBy" name="sort" class="form-select">
                        <option value="name_asc" <%= sortBy === 'name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
                        <option value="name_desc" <%= sortBy === 'name_desc' ? 'selected' : '' %>>Name (Z-A)</option>
                        <option value="age_asc" <%= sortBy === 'age_asc' ? 'selected' : '' %>>Age (Youngest)</option>
                        <option value="age_desc" <%= sortBy === 'age_desc' ? 'selected' : '' %>>Age (Oldest)</option>
                        <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest First</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="submit" class="btn btn-primary w-100">Apply</button>
                </div>
            </form>
            <div class="mt-2">
                <a href="/" class="btn btn-outline-secondary btn-sm">Clear Filters</a>
            </div>
        </div>
        <% if (pets && pets.length > 0) { %>
            <div class="row">
                <% for (let i = 0; i < pets.length; i++) { %>
                    <div class="col-md-4 col-lg-3 mb-4">
                        <div class="card h-100">
                            <!-- Pet Image -->
                            <% if (pets[i].image_path) { %>
                                <img src="/uploads/<%= pets[i].image_path %>" class="card-img-top" alt="<%= pets[i].pet_name %>" style="height: 200px; object-fit: cover;">
                            <% } else { %>
                                <div class="card-img-top bg-secondary bg-opacity-10 text-center p-5" style="height: 200px;">
                                    No Image
                                </div>
                            <% } %>
                            
                            <div class="card-body">
                                <h5 class="card-title"><%= pets[i].pet_name %></h5>
                                
                                <div class="mb-2">
                                    <span class="badge bg-primary"><%= pets[i].animal_type || 'Unknown' %></span>
                                    <span class="badge bg-secondary"><%= pets[i].age || 'N/A' %> yrs</span>
                                    <% if (pets[i].breed) { %>
                                        <span class="badge bg-info text-dark"><%= pets[i].breed %></span>
                                    <% } %>
                                </div>
                                
                                <p class="card-text">
                                    <% 
                                        let description = pets[i].description || 'No description available.';
                                        if (description.length > 100) {
                                            description = description.substring(0, 100) + '...';
                                        }
                                    %>
                                    <%= description %>
                                </p>
                                
                                <!-- Allergies -->
                                <% if (pets[i].allergies) { %>
                                    <div class="alert alert-warning py-1 px-2 small">
                                        Allergies: <%= pets[i].allergies %>
                                    </div>
                                <% } %>
                                
                                <a href="/pet/<%= pets[i].id %>" class="btn btn-outline-primary btn-sm">View Details</a>
                                
                                <!-- Edit/Delete -->
                                <% if (user && (user.role === 'admin' || pets[i].user_id === user.id)) { %>
                                    <div class="mt-2">
                                        <a href="/edit/<%= pets[i].id %>" class="btn btn-primary btn-sm">Edit</a>
                                        <form action="/delete/<%= pets[i].id %>" method="POST" style="display: inline;" 
                                              onsubmit="return confirm('Are you sure you want to delete this pet?');">
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="text-center p-5 bg-light rounded">
                <h4>No pets found</h4>
                <p class="text-muted">
                    <% if (searchTerm || selectedType) { %>
                        No pets match your search criteria. Try adjusting your filters!
                        <br>
                        <a href="/" class="btn btn-primary mt-3">Clear Filters</a>
                    <% } else { %>
                        There are currently no pets available for adoption.
                        <% if (user) { %>
                            <br>
                            <a href="/add" class="btn btn-primary mt-3">Add a Pet</a>
                        <% } else { %>
                            <br>
                            <a href="/login" class="btn btn-primary mt-3">Login to Add Pets</a>
                        <% } %>
                    <% } %>
                </p>
            </div>
        <% } %>
    </div>
</body>
</html>