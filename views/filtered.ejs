<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Filtered Pets</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    body {
      background-color: #FFF4E6;
    }

    body {
      font-family: Optima, Candara, 'Century Gothic', sans-serif;
    }

    nav {
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
    }
</style>
</head>
<body class=>
  <div class="container mt-5">
    <h1 class="text-center mb-4 fw-bold">Filtered Results</h1>
    
    <a href="/filter" class="btn btn-secondary mb-4">Back to Filter</a>

    <% if (pet.length === 0) { %>
      <p class="text-center text-muted">No pets match your filters.</p>
    <% } else { %>
      <div class="row">
        <% pet.forEach(p => { %>
          <%- include('card', { pet: p }) %>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
