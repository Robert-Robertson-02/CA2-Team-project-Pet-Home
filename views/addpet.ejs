<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Pet Home</title>
  </head>
  <body>
      <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/">Pet Home</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="collapsibleNavbar">
            <ul class="navbar-nav">
              <% if (user) { %>
                <li class="nav-item">
                  <a class="nav-link" href="/add">Add Pet</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/logout">Logout</a>
                </li>
              <% } else { %>
                <li class="nav-item">
                  <a class="nav-link" href="/register">Register</a>
                </li>
                <li class="nav-item">
                  <a class="nav-link" href="/login">Login</a>
                </li>
              <% } %>
            </ul>
          </div>
        </div>
      </nav>
      <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p><%= error %></p>
                <% }); %>
            </div>
        <% } %>
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p><%= message %></p>
                <% }); %>
            </div>
        <% } %>
      <form action="/add" method="POST" enctype="multipart/form-data">

            <label for="pet_name">Pet Name:</label>
            <input type="text" id="pet_name" name="pet_name">
            <br>

            <label for="age">Age:</label>
            <input type="number" id="age" name="age">
            <br>

            <label for="animal_type">Type of Animal:</label>
            <input type="text" id="animal_type" name="animal_type">
            <br>

            <label for="breed">Breed:</label>
            <input type="text" id="breed" name="breed">
            <br>

            <label for="allergies">Allergies:</label>
            <input type="text" id="allergies" name="allergies">
            <br>

            <label for="image">Pet Photo:</label>
            <input type="file" id="image" name="image">
            <br>

            <label for="description">Description:</label>
            <textarea id="description" name="description"></textarea>
            <br>

            <button type="submit">Add Pet</button>

        </form>
    </body>
</html>