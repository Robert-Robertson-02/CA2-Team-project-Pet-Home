<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Pet Home</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body>
    <style>
        body {
            background-color: #FFF4E6; 
        }
        body {
    font-family: Optima, Candara, 'Century Gothic', sans-serif;
}
nav {
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
}
    </style>
    
      <nav class="navbar navbar-expand-sm navbar-light sticky-top" style="background-color: #C4A484;">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="me-2">Pet Home</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/add">
                                    <span class="me-1"></span> Add Pet
                                </a>
                            </li>
                        <% } %>
                      
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/recentlyDeleted">
                                    <span class="me-1"></span> Recently Deleted
                                </a>
                            </li>
                        <% } %>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="/filter">
                                <span class="me-1"></span> Filter
                            </a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="/adopted">
                                <span class="me-1"></span> Adopted Pets
                            </a>
                        </li>
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <%= user.username || 'User' %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        
                        <li class="nav-item">
                            <a class="nav-link" href="/register">
                                <span class="me-1"></span> Register
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <span class="me-1"></span> Login
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>
      <% if (errors && errors.length > 0) { %>
            <div class="container mt-3">
                <div class="alert alert-danger">
                    <% errors.forEach(function(error) { %>
                        <p class="mb-0"><%= error %></p>
                    <% }); %>
                </div>
            </div>
        <% } %>
        <% if (messages && messages.length > 0) { %>
            <div class="container mt-3">
                <div class="alert alert-success">
                    <% messages.forEach(function(message) { %>
                        <p class="mb-0"><%= message %></p>
                    <% }); %>
                </div>
            </div>
        <% } %>

      <div class="container mt-5" style="max-width: 600px;">
          <div class="card shadow-sm">
              <div class="card-body p-4">
                  <h2 class="card-title fw-bold mb-4 text-center">Add a New Pet</h2>

                  <form action="/add" method="POST" enctype="multipart/form-data">

                      <div class="mb-3">
                          <label for="pet_name" class="form-label">Pet Name</label>
                          <input type="text" class="form-control" id="pet_name" name="pet_name">
                      </div>

                      <div class="row mb-3">
                          <div class="col">
                              <label for="animal_type" class="form-label">Type of Animal</label>
                              <input type="text" class="form-control" id="animal_type" name="animal_type">
                          </div>
                          <div class="col">
                              <label for="age" class="form-label">Age</label>
                              <input type="number" class="form-control" id="age" name="age">
                          </div>
                      </div>

                      <div class="mb-3">
                          <label for="breed" class="form-label">Breed</label>
                          <input type="text" class="form-control" id="breed" name="breed">
                      </div>

                      <div class="mb-3">
                          <label for="allergies" class="form-label">Allergies</label>
                          <input type="text" class="form-control" id="allergies" name="allergies">
                      </div>

                      <div class="mb-3">
                          <label for="image" class="form-label">Pet Photo</label>
                          <input type="file" class="form-control" id="image" name="image">
                      </div>

                      <div class="mb-4">
                          <label for="description" class="form-label">Description</label>
                          <textarea class="form-control" id="description" name="description" rows="4"></textarea>
                      </div>

                      <button type="submit" class="btn btn-primary w-100">Add Pet</button>

                  </form>
              </div>
          </div>
      </div>
    </body>
</html>
