<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Adopted Pets - Pet Home</title>
    <style>
        body {
            background-color: #FFF4E6;
            font-family: Optima, Candara, 'Century Gothic', sans-serif;
        }

        nav {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="me-2">Pet Home</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/add">Add Pet</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/recentlyDeleted">Recently Deleted</a>
                            </li>
                        <% } %>
                        <li class="nav-item">
                            <a class="nav-link" href="/filter">Filter</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link active" href="/adopted">Adopted Pets</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <%= user.username || 'User' %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/register">Register</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        <!-- Page Header -->
        <div class="text-center mb-4">
            <h1 class="display-5 fw-bold">Adopted Pets</h1>
            <p class="text-muted">These wonderful pets have found their forever homes!</p>
        </div>

        <!-- Pet Cards Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% if (pets && pets.length > 0) { %>
                <% pets.forEach(function(pet) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm pet-card">
                            <!-- Pet Image -->
                            <div style="height: 200px; overflow: hidden; position: relative;">
                                <% if (pet.image && pet.image !== 'null' && pet.image !== '') { %>
                                     <img src="/adopted-pet-image/<%= pet.pet_id %>" alt="<%= pet.pet_name %>"
                                        style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
                                <% } else { %>
                                    <div class="d-flex justify-content-center align-items-center h-100 text-secondary"
                                        style="font-size: 4rem; background-color: #f8f9fa;">
                                        No Image
                                    </div>
                                <% } %>
                            </div>

                            <!-- Pet Details -->
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title fw-bold mb-0">
                                        <%= pet.pet_name %>
                                    </h5>
                                    <span class="badge bg-secondary">
                                        <%= pet.animal_type || 'Pet' %>
                                    </span>
                                </div>

                                <div class="mb-2">
                                    <span class="badge bg-info me-1">Age: <%= pet.age || 'Unknown' %></span>
                                    <span class="badge bg-warning text-dark">Breed: <%= pet.breed || 'Unknown' %></span>
                                </div>

                                <% if (pet.description) { %>
                                    <p class="card-text text-muted" style="font-size: 0.9rem;">
                                        <%= pet.description.length > 100 ? pet.description.substring(0, 100) + '...' : pet.description %>
                                    </p>
                                <% } else { %>
                                    <p class="card-text text-muted fst-italic" style="font-size: 0.9rem;">
                                        No description provided
                                    </p>
                                <% } %>

                                <p class="card-text" style="font-size: 0.8rem;">
                                    <small class="text-muted">
                                        Added by: <%= pet.username || 'Unknown User' %>
                                    </small>
                                </p>

                                <!-- Adopted Status -->
                                <div class="mt-2 p-2 bg-success bg-opacity-10 rounded-3">
                                    <p class="mb-0 text-success" style="font-size: 0.85rem;">
                                        <strong>Adopted!</strong>
                                        <% if (pet.moved) { %>
                                            <br>
                                            <span class="text-muted" style="font-size: 0.8rem;">
                                                Adopted on: <%= new Date(pet.moved).toLocaleDateString() %>
                                            </span>
                                        <% } %>
                                    </p>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="card-footer bg-transparent border-top-0">
                                <div class="d-grid gap-2">
                                    <% if (user && user.role === 'admin') { %>
                                        <div class="d-flex gap-2">
                                            <a href="/pets/edit/<%= pet.pet_id %>" class="btn btn-outline-warning btn-sm flex-grow-1">
                                                Edit
                                            </a>
                                            <a href="/recetnlyDeleted/<%= pet.pet_id %>" class="btn btn-outline-danger btn-sm flex-grow-1" 
                                               onclick="return confirm('Are you sure you want to delete this pet?');">
                                                Delete
                                            </a>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12">
                    <div class="text-center p-5 bg-light rounded-3">
                        <div style="font-size: 5rem; margin-bottom: 1rem;">No Image</div>
                        <h3 class="mb-3">No Adopted Pets Yet</h3>
                        <p class="text-muted mb-4">No pets have been adopted yet. Be the first to adopt a furry friend!</p>
                        <a href="/" class="btn btn-primary">
                            View Available Pets
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

</body>
</html>
