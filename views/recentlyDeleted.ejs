<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Recently Deleted - Pet Home</title>

    <style>
        body {
            background-color: #FFF4E6;
            font-family: Optima, Candara, 'Century Gothic', sans-serif;
        }

        nav {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>

<body>
    <!-- Navigation (same logic & style as index.ejs) -->
    <nav class="navbar navbar-expand-sm blue-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="me-2">Pet Home</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <!-- Show Add Pet ONLY for Admins -->
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/add">
                                    <span class="me-1"></span> Add Pet
                                </a>
                            </li>
                        <% } %>

                        <!-- Show Recently Deleted ONLY for Admins -->
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link active" href="/recentlyDeleted">
                                    <span class="me-1"></span> Recently Deleted
                                </a>
                            </li>
                        <% } %>

                        <!-- Common links for ALL logged-in users -->
                        <li class="nav-item">
                            <a class="nav-link" href="/filter">
                                <span class="me-1"></span> Filter
                            </a>
                        </li>

                        <!-- Adopted Pets - For logged-in users -->
                        <li class="nav-item">
                            <a class="nav-link" href="/adopted">
                                <span class="me-1"></span> Adopted Pets
                            </a>
                        </li>

                        <!-- User Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                data-bs-toggle="dropdown">
                                <%= user.username || 'User' %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <!-- Guest links - Show ONLY when NOT logged in -->
                        <li class="nav-item">
                            <a class="nav-link" href="/register">
                                <span class="me-1"></span> Register
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <span class="me-1"></span> Login
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">

        <div class="text-center mb-4">
            <h1 class="display-5 fw-bold">Recently Deleted Pets</h1>
            <p class="text-muted">Restore a pet or permanently remove it.</p>
        </div>

        <div class="d-flex justify-content-center mb-4">
            <span class="badge bg-danger p-3 fs-6">
                <%= (pets && pets.length) ? pets.length : 0 %> Deleted Pet<%= (pets && pets.length) !== 1 ? "s" : "" %>
            </span>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            <% if (pets && pets.length > 0) { %>

                <% pets.forEach(function(pet) { %>
                    <div class="col">
                        <div class="card h-100 shadow-sm pet-card">
                            <!-- Pet Image -->
                            <div style="height: 200px; overflow: hidden; position: relative;">
                                <% if (pet.image && pet.image !== 'null' && pet.image !== '') { %>
                                    <img src="/pet-image/<%= pet.pet_id %>" alt="<%= pet.pet_name %>"
                                        style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
                                <% } else { %>
                                    <div class="d-flex justify-content-center align-items-center h-100 text-secondary"
                                        style="font-size: 2rem; background-color: #f8f9fa;">
                                        No Image
                                    </div>
                                <% } %>
                            </div>

                            <!-- Pet Details -->
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title fw-bold mb-0">
                                        <%= pet.pet_name %>
                                    </h5>
                                    <span class="badge bg-secondary">
                                        <%= pet.animal_type || 'Pet' %>
                                    </span>
                                </div>

                                <div class="mb-2">
                                    <span class="badge bg-info me-1">Age: <%= pet.age || 'Unknown' %></span>
                                    <span class="badge bg-warning text-dark">Breed: <%= pet.breed || 'Unknown' %></span>
                                </div>

                                <% if (pet.description) { %>
                                    <p class="card-text text-muted" style="font-size: 0.9rem;">
                                        <%= pet.description.length > 100 ? pet.description.substring(0, 100) + '...' : pet.description %>
                                    </p>
                                <% } else { %>
                                    <p class="card-text text-muted fst-italic" style="font-size: 0.9rem;">
                                        No description provided
                                    </p>
                                <% } %>

                                <p class="card-text" style="font-size: 0.8rem;">
                                    <small class="text-muted">Deleted by: <%= pet.username || 'Unknown User' %></small>
                                </p>
                            </div>

                            <!-- Action Buttons -->
                            <div class="card-footer bg-transparent border-top-0">
                                <div class="d-grid gap-2">
                                    <div class="d-flex gap-2">
                                        <a href="/restorePet/<%= pet.pet_id %>" class="btn btn-success btn-sm flex-grow-1">
                                            Restore
                                        </a>
                                        <a href="/permanentDelete/<%= pet.pet_id %>"
                                            class="btn btn-danger btn-sm flex-grow-1"
                                            onclick="return confirm('Permanently delete this pet? This cannot be undone.')">
                                            Delete Forever
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>

            <% } else { %>

                <div class="col-12">
                    <div class="text-center p-5 bg-light rounded-3">
                        <div style="font-size: 5rem; margin-bottom: 1rem;">🗑️</div>
                        <h3 class="mb-3">No Deleted Pets</h3>
                        <p class="text-muted">
                            Your recycle bin is empty.
                        </p>
                        <a href="/" class="btn btn-primary">
                            Back to Home
                        </a>
                    </div>
                </div>

            <% } %>

        </div>
    </div>

    <!-- Footer (same as index.ejs) -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-1"> Pet Home - Find Your Perfect Companion</p>
            <p class="mb-0 text-muted" style="font-size: 0.9rem;">© 2026 Pet Home. All rights reserved.</p>
        </div>
    </footer>
</body>

</html>
