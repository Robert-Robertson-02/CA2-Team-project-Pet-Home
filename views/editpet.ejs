<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Pet</title>
<style>
body{
    background:#FFF4E6;
    font-family:Optima, Candara, 'Century Gothic', sans-serif;
    margin:0;
}

nav{
    background:white;
    box-shadow:0 4px 10px rgba(0,0,0,.25);
    padding:15px 0;
}

.container{
    width:90%;
    max-width:1300px;
    margin:auto;
}

nav .container{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.nav-brand a,
.nav-links a{
    text-decoration:none;
    color:#222;
    font-weight:bold;
    margin-left:20px;
}

h1{
    font-size:50px;
    margin:35px 0;
}

.edit-layout{
    display:grid;
    grid-template-columns:380px 1fr;
    gap:70px;
    align-items:start;
}

.current-image img{
    width:100%;
    height:350px;
    object-fit:cover;
    border-radius:6px;
}

.form-group{
    margin-bottom:20px;
}

.form-group label{
    display:block;
    font-size:18px;
    font-weight:bold;
    margin-bottom:8px;
}

input[type=text],
input[type=number],
select,
textarea{
    width:100%;
    padding:14px;
    font-size:17px;
    border:1px solid #d4d4d4;
    border-radius:12px;
    box-sizing:border-box;
}

textarea{
    height:220px;
    resize:none;
}

input[type=file]{
    margin-top:10px;
}

.form-actions{
    margin-top:25px;
    display:flex;
    gap:15px;
}

.form-actions a{
    background:#6c757d;
    color:white;
    padding:12px 28px;
    text-decoration:none;
    border-radius:8px;
}

.form-actions button{
    background:#198754;
    color:white;
    border:none;
    padding:12px 28px;
    border-radius:8px;
    cursor:pointer;
}

.form-actions button:hover{
    background:#157347;
}

.alert{
    padding:15px;
    border-radius:8px;
    margin-bottom:20px;
}

.alert-error{
    background:#f8d7da;
}

.alert-success{
    background:#d1e7dd;
}

.help-text{
    color:#666;
    font-size:14px;
}

@media(max-width:900px){

.edit-layout{
    grid-template-columns:1fr;
}

.current-image img{
    height:auto;
}
}
</style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container">
            <div class="nav-brand">
                <a href="/" style="margin-left: 0;">Pet Adoption</a>
            </div>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/filter">Browse Pets</a>
                <% if (user) { %>
                    <a href="/add">Add Pet</a>
                    <a href="/recentlyDeleted">Deleted Pets</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1>Edit Pet</h1>
        
        <!-- Display error messages -->
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-error">
                <% errors.forEach(function(error) { %>
                    <div><%= error %></div>
                <% }); %>
            </div>
        <% } %>
        
        <!-- success messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <div><%= message %></div>
                <% }); %>
            </div>
        <% } %>
    <form action="/pets/update/<%= pet.pet_id %>"
        method="POST"
        enctype="multipart/form-data">
        <div class="edit-layout">

    <!-- LEFT SIDE -->
    <div>

        <div class="form-group">
            <label>Current Image</label>

            <div class="current-image">
                <% if (pet.image) { %>
                    <img src="/pet-image/<%= pet.pet_id %>" alt="<%= pet.pet_name %>">
                <% } else { %>
                    <p><em>No image uploaded</em></p>
                <% } %>
            </div>
        </div>

        <div class="form-group">
            <label for="image">Upload New Image</label>
            <input type="file" id="image" name="image" accept="image/*">
            <p class="help-text">Leave blank to keep current image</p>
        </div>

    </div>

    <!-- RIGHT SIDE -->
    <div>

        <div class="form-group">
            <label for="description">Description</label>

            <textarea id="description" name="description"><%= pet.description || '' %></textarea>
        </div>

        <div class="form-group">
            <label for="pet_name">Pet Name</label>

            <input
                type="text"
                id="pet_name"
                name="pet_name"
                value="<%= pet.pet_name %>"
                required>
        </div>

        <div class="form-group">
            <label for="breed">Breed</label>

            <input
                type="text"
                id="breed"
                name="breed"
                value="<%= pet.breed %>"
                required>
        </div>

        <div class="form-group">
            <label for="animal_type">Animal Type</label>

            <select id="animal_type" name="animal_type">

                <option value="Dog" <%= pet.animal_type==='Dog'?'selected':'' %>>Dog</option>

                <option value="Cat" <%= pet.animal_type==='Cat'?'selected':'' %>>Cat</option>

                <option value="Bird" <%= pet.animal_type==='Bird'?'selected':'' %>>Bird</option>

                <option value="Rabbit" <%= pet.animal_type==='Rabbit'?'selected':'' %>>Rabbit</option>

                <option value="Hamster" <%= pet.animal_type==='Hamster'?'selected':'' %>>Hamster</option>

                <option value="Fish" <%= pet.animal_type==='Fish'?'selected':'' %>>Fish</option>

                <option value="Reptile" <%= pet.animal_type==='Reptile'?'selected':'' %>>Reptile</option>

                <option value="Other" <%= pet.animal_type==='Other'?'selected':'' %>>Other</option>

            </select>
        </div>

        <div class="form-group">
            <label for="age">Age</label>

            <input
                type="number"
                id="age"
                name="age"
                value="<%= pet.age %>"
                min="0.1"
                step="0.1"
                required>
        </div>

        <div class="form-group">
            <label for="allergies">Allergies / Medical Conditions</label>

            <input
                type="text"
                id="allergies"
                name="allergies"
                value="<%= pet.allergies || '' %>">
        </div>

        <div class="form-actions">
            <a href="/">Cancel</a>

            <button type="submit">
                Update Pet
            </button>
        </div>

    </div>

</div>
    </form>
    </div>
</body>
</html>
