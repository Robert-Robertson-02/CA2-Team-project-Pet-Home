<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Pet</title>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="container">
            <div class="nav-brand">
                <a href="/" style="margin-left: 0;">Pet Adoption</a>
            </div>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/filter">Browse Pets</a>
                <% if (user) { %>
                    <a href="/add">Add Pet</a>
                    <a href="/recentlyDeleted">Deleted Pets</a>
                    <a href="/logout">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register">Register</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container">
        <h1>Edit Pet</h1>
        
        <!-- Display error messages -->
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-error">
                <% errors.forEach(function(error) { %>
                    <div><%= error %></div>
                <% }); %>
            </div>
        <% } %>
        
        <!-- success messages -->
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <div><%= message %></div>
                <% }); %>
            </div>
        <% } %>

        <form action="/pets/<%= pet.pet_id %>/update" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="pet_name">Pet Name <span class="required">*</span></label>
                <input type="text" id="pet_name" name="pet_name" value="<%= pet.pet_name %>" required>
            </div>
            
            <div class="form-group">
                <label for="animal_type">Animal Type <span class="required">*</span></label>
                <select id="animal_type" name="animal_type" required>
                    <option value="">Select type</option>
                    <option value="Dog" <%= pet.animal_type === 'Dog' ? 'selected' : '' %>>Dog</option>
                    <option value="Cat" <%= pet.animal_type === 'Cat' ? 'selected' : '' %>>Cat</option>
                    <option value="Bird" <%= pet.animal_type === 'Bird' ? 'selected' : '' %>>Bird</option>
                    <option value="Rabbit" <%= pet.animal_type === 'Rabbit' ? 'selected' : '' %>>Rabbit</option>
                    <option value="Hamster" <%= pet.animal_type === 'Hamster' ? 'selected' : '' %>>Hamster</option>
                    <option value="Fish" <%= pet.animal_type === 'Fish' ? 'selected' : '' %>>Fish</option>
                    <option value="Reptile" <%= pet.animal_type === 'Reptile' ? 'selected' : '' %>>Reptile</option>
                    <option value="Other" <%= pet.animal_type === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="breed">Breed <span class="required">*</span></label>
                <input type="text" id="breed" name="breed" value="<%= pet.breed %>" required>
            </div>
            
            <div class="form-group">
                <label for="age">Age (in years) <span class="required">*</span></label>
                <input type="number" id="age" name="age" value="<%= pet.age %>" min="0.1" step="0.1" required>
            </div>
            
            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" placeholder="Tell us about this pet's personality, behavior, and special needs..."><%= pet.description || '' %></textarea>
            </div>
            
            <div class="form-group">
                <label for="allergies">Allergies / Medical Conditions</label>
                <input type="text" id="allergies" name="allergies" value="<%= pet.allergies || '' %>" placeholder="Any known allergies or medical conditions">
            </div>
            
            <div class="form-group">
                <label>Current Image</label>
                <div class="current-image">
                    <!-- FIXED: Display image using the pet-image route -->
                    <% if (pet.image) { %>
                        <img src="/pet-image/<%= pet.pet_id %>" alt="<%= pet.pet_name %>">
                        <p><small>Current image is displayed</small></p>
                    <% } else { %>
                        <p><em>No image uploaded</em></p>
                    <% } %>
                </div>
            </div>
            
            <div class="form-group">
                <label for="image">Upload New Image (optional)</label>
                <input type="file" id="image" name="image" accept="image/*">
                <p class="help-text">Leave blank to keep current image</p>
            </div>
            
            <div class="form-actions">
                <a href="/">Cancel</a>
                <button type="submit">Update Pet</button>
            </div>
        </form>
    </div>
</body>
</html>
