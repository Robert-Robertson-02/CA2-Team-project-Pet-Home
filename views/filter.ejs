<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>What Are You Looking For?</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/custom.css">

    <style>
        body {
            background-color: #FFF4E6;
        }

        body {
            font-family: Optima, Candara, 'Century Gothic', sans-serif;
        }

        nav {
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>

<body class>
<!-- Navigation -->
    <nav class="navbar navbar-expand-sm blue-navbar sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="me-2">Pet Home</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <!-- Show Add Pet ONLY for Admins -->
                        <% if (user.role==='admin' ) { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/add">
                                    <span class="me-1"></span> Add Pet
                                </a>
                            </li>
                            <% } %>

                                <!-- Show Recently Deleted ONLY for Admins -->
                                <% if (user.role==='admin' ) { %>
                                    <li class="nav-item">
                                        <a class="nav-link" href="/recentlyDeleted">
                                            <span class="me-1"></span> Recently Deleted
                                        </a>
                                    </li>
                                    <% } %>

                                        <!-- Common links for ALL logged-in users -->
                                        <li class="nav-item">
                                            <a class="nav-link" href="/filter">
                                                <span class="me-1"></span> Filter
                                            </a>
                                        </li>

                                        <!-- Adopted Pets - For logged-in users -->
                                        <li class="nav-item">
                                            <a class="nav-link" href="/adopted">
                                                <span class="me-1"></span> Adopted Pets
                                            </a>
                                        </li>

                                        <!-- User Dropdown -->
                                        <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                                                data-bs-toggle="dropdown">
                                                <%= user.username || 'User' %>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                                            </ul>
                                        </li>
                                        <% } else { %>

                                            <!-- Guest links - Show ONLY when NOT logged in -->
                                            <li class="nav-item">
                                                <a class="nav-link" href="/register">
                                                    <span class="me-1"></span> Register
                                                </a>
                                            </li>
                                            <li class="nav-item">
                                                <a class="nav-link" href="/login">
                                                    <span class="me-1"></span> Login
                                                </a>
                                            </li>
                                            <% } %>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-5">
        <h1 class="text-center mb-4 fw-bold">What Are You Looking For?</h1>
        <div class="text-center mb-4">
            <h3> Search for pets by Name or Description</h3>

            <form action="/filtered" method="get" class="mb-3">
                <div class="d-flex">
                    <input type="text" name="search" class="form-control me-2"
                        placeholder="Search by Name or Description">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
        </div>
        </form>
        <div class="text-center mb-4">
            <h3>Filter by Attributes</h3>
            <form action="/filtered" method="GET" class="p-4 bg-white rounded shadow-sm">
                <div class="row">
                    <!-- Breed -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Breed</h5>
                        <% breeds.forEach(b=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="breed[]" value="<%= b.breed %>">
                                <label class="form-check-label">
                                    <%= b.breed %>
                                </label>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Type -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Type</h5>
                        <% type.forEach(t=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="animal_type[]" value="<%= t.animal_type %>">
                                <label class="form-check-label">
                                    <%= t.animal_type %>
                                </label>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Age -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Age</h5>
                        <% ages.forEach(a=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="age[]" value="<%= a.age %>">
                                <label class="form-check-label">
                                    <%= a.age %>
                                </label>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-4">Filter</button>
                </div>

                <div class="text-center mt-3">
                    <a href="/" class="btn btn-secondary px-4">Back to Home</a>
                </div>
            </form>
        </div>
</body>

</html>
