<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>What Are You Looking For?</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/custom.css">

</head>

<body class="bg-light">
    <div class="container mt-5">
        <h1 class="text-center mb-4 fw-bold">What Are You Looking For?</h1>
        <div class="text-center mb-4">
            <h3> Search for pets by Name or Description</h3>

            <form action="/filtered" method="get" class="mb-3">
                <div class="d-flex">
                    <input type="text" name="search" class="form-control me-2"
                        placeholder="Search by Name or Description">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
        </div>
        </form>
        <div class="text-center mb-4">
            <h3>Filter by Attributes</h3>
            <form action="/filtered" method="GET" class="p-4 bg-white rounded shadow-sm">
                <div class="row">
                    <!-- Breed -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Breed</h5>
                        <% breeds.forEach(b=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="breed[]" value="<%= b.breed %>">
                                <label class="form-check-label">
                                    <%= b.breed %>
                                </label>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Type -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Type</h5>
                        <% type.forEach(t=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="animal_type[]" value="<%= t.animal_type %>">
                                <label class="form-check-label">
                                    <%= t.animal_type %>
                                </label>
                            </div>
                            <% }) %>
                    </div>

                    <!-- Age -->
                    <div class="col-md-4">
                        <h5 class="fw-semibold mb-3">Age</h5>
                        <% ages.forEach(a=> { %>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="age[]" value="<%= a.age %>">
                                <label class="form-check-label">
                                    <%= a.age %>
                                </label>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-4">Filter</button>
                </div>

                <div class="text-center mt-3">
                    <a href="/" class="btn btn-secondary px-4">Back to Home</a>
                </div>
            </form>
        </div>
</body>

</html>
