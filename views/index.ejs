<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <title>Pet Home - Find Your Perfect Companion</title>

    <style>
        /* Background color for the whole page */
        body {
            background-color: #FFF4E6; 
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <span class="me-2">Pet Home</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav ms-auto">
                    <% if (user) { %>
                        <!-- Show Add Pet ONLY for Admins -->
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/add">
                                    <span class="me-1"></span> Add Pet
                                </a>
                            </li>
                        <% } %>
                        
                        <!-- Show Recently Deleted ONLY for Admins -->
                        <% if (user.role === 'admin') { %>
                            <li class="nav-item">
                                <a class="nav-link" href="/recentlyDeleted">
                                    <span class="me-1"></span> Recently Deleted
                                </a>
                            </li>
                        <% } %>
                        
                        <!-- Common links for ALL logged-in users -->
                        <li class="nav-item">
                            <a class="nav-link" href="/filter">
                                <span class="me-1"></span> Filter
                            </a>
                        </li>
                        
                        <!-- Adopted Pets - For logged-in users -->
                        <li class="nav-item">
                            <a class="nav-link" href="/adopted">
                                <span class="me-1"></span> Adopted Pets
                            </a>
                        </li>
                        
                        <!-- User Dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <%= user.username || 'User' %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        
                        <!-- Guest links - Show ONLY when NOT logged in -->
                        <li class="nav-item">
                            <a class="nav-link" href="/register">
                                <span class="me-1"></span> Register
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login">
                                <span class="me-1"></span> Login
                            </a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Flash Messages -->
    <% if (messages && messages.length > 0) { %>
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <span class="me-2"></span> <%= messages %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>
    
    <% if (errors && errors.length > 0) { %>
        <div class="container mt-3">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <span class="me-2"></span> <%= errors %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    <% } %>

    <!-- Main Content -->
    <div class="container mt-4">
        <!-- Page Header -->
        <div class="text-center mb-4">
            <h1 class="display-5 fw-bold">Find Your Perfect Companion</h1>
            <p class="text-muted">Discover adorable pets waiting for their forever home</p>
        </div>

        <!-- Pet Count Badge -->
        <div class="d-flex justify-content-center mb-4">
            <span class="badge bg-secondary p-3 fs-6">
                <%= pets.length %> pet<% if (pets.length !== 1) { %>s<% } %> currently looking for a home
            </span>
        </div>

        <!-- Pet Cards Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% if (pets && pets.length > 0) { %>
                <% pets.forEach(function(pet) { %>
                    <div class="col">
                        <%- include('card', { pet: pet, user: user }) %>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12">
                    <div class="text-center p-5 bg-light rounded-3">
                        <div style="font-size: 5rem; margin-bottom: 1rem;">🐾</div>
                        <h3 class="mb-3">No Pets Available</h3>
                        <p class="text-muted mb-4">We don't have any pets available for adoption at the moment.</p>
                        <% if (user) { %>
                            <% if (user.role === 'admin') { %>
                                <!-- Show Add Pet button ONLY for Admins -->
                                <a href="/add" class="btn btn-primary btn-lg">
                                    Add a Pet (Admin Only)
                                </a>
                            <% } else { %>
                                <!-- Regular users see this message -->
                                <p class="text-muted">Check back later for new pets!</p>
                            <% } %>
                        <% } else { %>
                            <p class="text-muted">
                                <a href="/register">Register</a> or <a href="/login">Login</a> to view more
                            </p>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-4 mt-5">
        <div class="container">
            <p class="mb-1"> Pet Home - Find Your Perfect Companion</p>
            <p class="mb-0 text-muted" style="font-size: 0.9rem;">© 2026 Pet Home. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
