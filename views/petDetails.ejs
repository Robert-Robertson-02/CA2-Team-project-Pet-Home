<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= pet.Name %> - Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .pet-image {
      width: 100%;
      max-width: 500px; /* bigger image */
      height: auto;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .desc-box {
      height: 250px; /* fixed height */
      overflow-y: auto; /* scroll if text too long */
      border: 1px solid #ddd;
      border-radius: 8px;
      padding: 15px;
      background-color: #fff;
    }
  </style>
</head>
<body class="bg-light">
  <div class="container mt-5">
    <h1 class="fw-bold mb-4"><%= pet.Name %></h1>

    <div class="row align-items-start">
      <!-- Left: Image -->
      <div class="col-md-6 text-center">
        <img src="/images/<%= pet.Picture %>" class="pet-image" alt="<%= pet.Name %>">
      </div>

      <!-- Right: Description box -->
      <div class="col-md-6">
        <h5 class="fw-semibold mb-3">Description</h5>
        <div class="desc-box mb-3">
          <p><%= pet.Description %></p>
        </div>

        <p><strong>Breed:</strong> <%= pet.Breed %></p>
        <p><strong>Type:</strong> <%= pet.Type %></p>
        <p><strong>Age:</strong> <%= pet.Age %></p>
        <form action="/adopt/<%= pet.pet_id %>" method="POST" class="d-inline">
        <button type="submit" class="btn btn-success mt-3">Adopt</button>
        </form>

        <a href="/filtered" class="btn btn-secondary mt-3">Back to Results</a>
      </div>
    </div>
  </div>
</body>
</html>
